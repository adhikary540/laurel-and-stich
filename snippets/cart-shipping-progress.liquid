{% comment %}
  Shopify Slide Cart - Free Shipping Progress Bar
  Paste this inside your slide cart drawer/cart sidebar section
{% endcomment %}

{% assign free_shipping_threshold = 100 %}

{% assign cart_total = cart.total_price | divided_by: 100.0 %}

{% assign progress_percentage = cart_total | times: 100 | divided_by: free_shipping_threshold %}

{% if progress_percentage > 100 %}
  {% assign progress_percentage = 100 %}
{% endif %}

<div class="free-shipping-bar">

  <div class="free-shipping-header">
    <span class="title">Free Shipping</span>

    <span class="cart-total">
      ${{ cart_total }}
    </span>
  </div>

  <div class="free-shipping-message">

    {% if cart_total >= free_shipping_threshold %}

      🎉 You unlocked <strong>FREE Shipping</strong>

    {% elsif progress_percentage >= 50 %}

      {% assign remaining_amount = free_shipping_threshold | minus: cart_total %}

      🚀 You're close! Add
      <strong>${{ remaining_amount }}</strong>
      more for free shipping.

    {% else %}

      {% assign remaining_amount = free_shipping_threshold | minus: cart_total %}

      🛍️ Add
      <strong>${{ remaining_amount }}</strong>
      more to unlock free shipping.

    {% endif %}

  </div>

  <div class="progress-track">
    <div
      class="progress-fill"
      style="width: {{ progress_percentage }}%;"
    ></div>
  </div>

  <div class="progress-labels">
    <span>$0</span>
    <span>${{ free_shipping_threshold }}</span>
  </div>

</div>

<style>
  .free-shipping-bar {
    padding: 16px;
    margin-bottom: 20px;
    background: #fff;
    border-radius: 14px;
    border: 1px solid #e5e7eb;
  }

  .free-shipping-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .free-shipping-header .title {
    font-size: 15px;
    font-weight: 700;
    color: #111827;
  }

  .free-shipping-header .cart-total {
    font-size: 13px;
    font-weight: 600;
    background: #f3f4f6;
    padding: 6px 10px;
    border-radius: 999px;
  }

  .free-shipping-message {
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 14px;
    color: #374151;
  }

  .progress-track {
    width: 100%;
    height: 10px;
    background: #e5e7eb;
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #111827, #22c55e);
    transition: width 0.4s ease;
  }

  .progress-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
    font-size: 12px;
    color: #6b7280;
  }

  @media screen and (max-width: 768px) {
    .free-shipping-bar {
      padding: 14px;
    }

    .free-shipping-message {
      font-size: 13px;
    }
  }
</style>