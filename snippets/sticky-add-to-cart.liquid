{% comment %}
  Sticky Mobile Add To Cart Bar
  Add inside:
  sections/main-product.liquid
  OR product template after main product form
{% endcomment %}

<style>
.sticky-mobile-atc {
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    background: rgb(253 253 253 / 96%);
    backdrop-filter: blur(10px);
    border-top: 1px solid #e5e7eb;
    padding: 12px 16px;
    z-index: 999;
    transform: translateY(120%);
    transition: transform 0.3s ease;
    box-shadow: 0 -4px 20px rgb(162 147 147 / 71%);
} 

  .sticky-mobile-atc.show {
    transform: translateY(0);
  }

  .sticky-atc-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    max-width: 100%;
  }

  .sticky-product-info {
    flex: 1;
    min-width: 0;
  }

  .sticky-product-title {
    font-size: 14px;
    font-weight: 600;
    color: #111827;
    margin: 0 0 4px;
    line-height: 1.3;
    
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .sticky-product-price {
    font-size: 14px;
    font-weight: 700;
    color: #111827;
  }

  .sticky-atc-button {
    border: none;
    background: #111827;
    color: #fff;
    padding: 14px 20px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: 0.25s ease;
  }

  .sticky-atc-button:hover {
    background: #000;
  }

  /* Desktop Hide */
  @media screen and (min-width: 769px) {
    .sticky-mobile-atc {
      display: none !important; 
    }
  }

  /* Prevent content overlap */
  @media screen and (max-width: 768px) {
    body {
      padding-bottom: 90px;
    }
  }
</style>  

<div class="sticky-mobile-atc" id="StickyMobileATC">

  <div class="sticky-atc-content">

    <div class="sticky-product-info">
      <h3 class="sticky-product-title">
        {{ product.title }}
      </h3>

      <div class="sticky-product-price">
        {{ product.selected_or_first_available_variant.price | money }}
      </div>
    </div>

    <button
      type="button"
      class="sticky-atc-button"
      id="StickyATCButton"
    >
      Add to Cart
    </button>

  </div>

</div>



<script>
  document.addEventListener('DOMContentLoaded', function () {

    const stickyBar = document.getElementById('StickyMobileATC');
    const stickyButton = document.getElementById('StickyATCButton');

    /*
      Main Product Form Button
      Shopify Dawn selector:
      [name="add"]

      Change selector if theme differs
    */
    const mainATCButton = document.querySelector(
      'form[action*="/cart/add"] [name="add"]'
    );

    if (!mainATCButton) return;

    // Show sticky bar only when main ATC leaves viewport
    const observer = new IntersectionObserver(
      ([entry]) => {

        if (!entry.isIntersecting) {
          stickyBar.classList.add('show');
        } else {
          stickyBar.classList.remove('show');
        }

      },
      {
        threshold: 0
      }
    );

    observer.observe(mainATCButton);

    // Trigger original add to cart button
    stickyButton.addEventListener('click', function () {
      mainATCButton.click();
    });

  });
</script> 